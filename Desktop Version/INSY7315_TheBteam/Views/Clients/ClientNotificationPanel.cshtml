@{
    Layout = null;
    var displayUser = ViewData["User"]?.ToString() ?? Context.Session.GetString("User");
    var displayEmail = ViewData["Email"]?.ToString() ?? Context.Session.GetString("Email");
    var displayRole = ViewData["Role"]?.ToString() ?? Context.Session.GetString("Role");
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Notifications - Axis IT</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
        :root {
            --bg1: #2c3e7d;
            --bg2: #4a5f9e;
            --accent: #8a78ea;
            --card: rgba(255,255,255,0.08);
            --white: #fff;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(135deg, #2a3c6e 0%, #3d5288 50%, #4a5f9e 100%);
            color: var(--white);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 48px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            background: rgba(0,0,0,0.1);
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .logo {
            width: 56px;
            height: 56px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.25rem;
            color: #2c3e7d;
        }

        .logo-text h1 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 600;
            letter-spacing: -0.5px;
        }

        .user-section {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .user-info {
            text-align: right;
        }

        .welcome-text {
            font-size: 0.95rem;
            font-weight: 600;
        }

        .role-badge {
            display: inline-block;
            background: rgba(138,120,234,0.3);
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 0.75rem;
            margin-top: 4px;
        }

        .user-email {
            font-size: 0.85rem;
            opacity: 0.8;
            margin-top: 2px;
        }

        .btn {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            color: var(--white);
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.2s ease;
            cursor: pointer;
        }

            .btn:hover {
                background: rgba(255,255,255,0.12);
            }

        .logout-btn {
            background: rgba(255,100,100,0.15);
            border: 1px solid rgba(255,100,100,0.3);
            color: #ffb8b8;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }

            .logout-btn:hover {
                background: rgba(255,100,100,0.25);
            }

        .main-content {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 24px;
        }

        .page-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .page-title {
            font-size: 2.5rem;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .page-sub {
            font-size: 1.05rem;
            opacity: 0.85;
        }

        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .stat-card {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 24px;
            text-align: center;
        }

        .stat-number {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .stat-label {
            font-size: 0.9rem;
            opacity: 0.8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .filter-bar {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 24px;
            padding: 16px;
            background: rgba(255,255,255,0.04);
            border-radius: 12px;
        }

        .filter-btn {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--white);
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }

            .filter-btn:hover {
                background: rgba(255,255,255,0.1);
            }

            .filter-btn.active {
                background: linear-gradient(135deg, #8a78ea 0%, #7b6bd9 100%);
                border-color: transparent;
            }

        .notifications-container {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .notification-card {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 24px;
            transition: all 0.2s ease;
            cursor: pointer;
        }

            .notification-card:hover {
                background: rgba(255,255,255,0.08);
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.2);
            }

            .notification-card.unread {
                border-left: 4px solid var(--accent);
                background: rgba(138,120,234,0.08);
            }

            .notification-card.success {
                border-left-color: #a8f5a8;
            }

            .notification-card.info {
                border-left-color: #8dd8ff;
            }

        .notification-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .notification-title {
            font-size: 1.1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .notification-badge {
            background: var(--accent);
            color: white;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .notification-time {
            font-size: 0.85rem;
            opacity: 0.7;
        }

        .notification-body {
            font-size: 0.95rem;
            line-height: 1.6;
            opacity: 0.9;
            margin-bottom: 12px;
        }

        .notification-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            font-size: 0.85rem;
            opacity: 0.8;
            margin-bottom: 16px;
        }

            .notification-meta span {
                background: rgba(255,255,255,0.06);
                padding: 4px 12px;
                border-radius: 6px;
            }

        .notification-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-small {
            padding: 8px 16px;
            font-size: 0.85rem;
            background: linear-gradient(135deg, #8a78ea 0%, #7b6bd9 100%);
            border: none;
        }

            .btn-small:hover {
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(138,120,234,0.3);
            }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }

        .empty-state-icon {
            font-size: 4rem;
            margin-bottom: 16px;
        }

        .empty-state-text {
            font-size: 1.1rem;
            opacity: 0.7;
        }

        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 4px solid rgba(255,255,255,0.1);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        @@media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 16px;
                padding: 20px 24px;
            }

            .user-section {
                flex-direction: column;
                width: 100%;
            }

            .user-info {
                text-align: center;
            }

            .page-title {
                font-size: 1.75rem;
            }

            .stats-row {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="logo-section">
            <div class="logo">AI</div>
            <div class="logo-text">
                <h1>Axis I.T</h1>
            </div>
        </div>

        <div class="user-section">
            <div class="user-info">
                <div class="welcome-text">@displayUser</div>
                @if (!string.IsNullOrEmpty(displayRole))
                {
                    <div class="role-badge">@displayRole</div>
                }
                @if (!string.IsNullOrEmpty(displayEmail))
                {
                    <div class="user-email">@displayEmail</div>
                }
            </div>
            <a href="/Home/Dashboard" class="btn">← Back to Dashboard</a>
            <a href="/Home/Logout" class="logout-btn">Logout</a>
        </div>
    </div>

    <div class="main-content">
        <div class="page-header">
            <div class="page-title">🔔 Notifications Center</div>
            <div class="page-sub">Stay updated on your project requests and important updates</div>
        </div>

        <div class="stats-row" id="statsRow">
            <div class="stat-card">
                <div class="stat-number" id="totalNotifications">0</div>
                <div class="stat-label">Total</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" id="unreadNotifications">0</div>
                <div class="stat-label">Unread</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" id="acceptedRequests">0</div>
                <div class="stat-label">Accepted</div>
            </div>
            <div class="stat-card">
                <div class="stat-number" id="pendingRequests">0</div>
                <div class="stat-label">Pending</div>
            </div>
        </div>

        <div class="filter-bar">
            <button class="filter-btn active" data-filter="all" onclick="filterNotifications('all')">
                All Notifications
            </button>
            <button class="filter-btn" data-filter="unread" onclick="filterNotifications('unread')">
                Unread
            </button>
            <button class="filter-btn" data-filter="accepted" onclick="filterNotifications('accepted')">
                ✅ Accepted
            </button>
            <button class="filter-btn" data-filter="pending" onclick="filterNotifications('pending')">
                ⏳ Pending
            </button>
            <button class="filter-btn" data-filter="progress" onclick="filterNotifications('progress')">
                📊 Progress Updates
            </button>
            <button class="filter-btn" onclick="markAllAsRead()" style="margin-left: auto;">
                Mark All as Read
            </button>
        </div>

        <div id="notificationsContainer" class="notifications-container">
            <div class="empty-state">
                <div class="loading-spinner"></div>
                <div class="empty-state-text">Loading your notifications...</div>
            </div>
        </div>
    </div>

    <script>
        const currentUserEmail = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(displayEmail ?? ""));
        const currentUserName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(displayUser ?? ""));

        let allNotifications = [];
        let currentFilter = 'all';
        let readNotifications = [];

        // Load read notifications from localStorage
        try {
            const stored = localStorage.getItem('readNotifications_' + currentUserEmail);
            readNotifications = stored ? JSON.parse(stored) : [];
        } catch (e) {
            console.error('Error loading read notifications:', e);
            readNotifications = [];
        }

        console.log('[Notifications] Logged in as:', currentUserEmail);

        async function loadNotifications() {
            try {
                const container = document.getElementById('notificationsContainer');
                allNotifications = [];

                console.log('[Notifications] Fetching project requests...');
                const requestsResp = await fetch('/Client/GetMyRequests');
                const requestsData = await requestsResp.json();
                console.log('[Notifications] Requests response:', requestsData);

                if (requestsData.success && Array.isArray(requestsData.data)) {
                    requestsData.data.forEach(req => {
                        const isAccepted = req.isAccepted || false;
                        const createdDate = new Date(req.createdAt);
                        const projectTitle = req.projectTitle || 'Untitled Project';
                        const budget = req.estimatedBudget || 0;
                        const requestId = req.id;

                        if (isAccepted) {
                            // Accepted request notification
                            allNotifications.push({
                                id: `accepted-${requestId}`,
                                type: 'success',
                                category: 'accepted',
                                title: '✅ Project Request Accepted',
                                body: `Great news! Your project request "${projectTitle}" has been approved and converted into an active project. A project manager will contact you soon to discuss the next steps.`,
                                time: createdDate,
                                meta: [
                                    `💰 Budget: R${Number(budget).toLocaleString()}`,
                                    `📋 Type: ${req.projectType || 'Construction'}`,
                                    `📍 Location: ${req.siteAddress || 'Not specified'}`
                                ],
                                unread: !readNotifications.includes(`accepted-${requestId}`),
                                actions: [
                                    { label: 'View Details', action: 'viewProject', projectId: requestId }
                                ],
                                requestData: req
                            });

                            // Progress update notification
                            allNotifications.push({
                                id: `progress-${requestId}`,
                                type: 'info',
                                category: 'progress',
                                title: '📊 Project Progress Update',
                                body: `Project "${projectTitle}" is now in progress. You'll receive regular updates on milestones and completion status.`,
                                time: new Date(createdDate.getTime() + 3600000),
                                meta: [
                                    `🎯 Status: In Progress`,
                                    `📅 Started: ${formatDate(createdDate)}`
                                ],
                                unread: !readNotifications.includes(`progress-${requestId}`),
                                actions: [
                                    { label: 'Check Status', action: 'checkStatus', projectId: requestId }
                                ],
                                requestData: req
                            });
                        } else {
                            // Pending request notification
                            allNotifications.push({
                                id: `pending-${requestId}`,
                                type: 'info',
                                category: 'pending',
                                title: '📝 Project Request Submitted',
                                body: `Your project request "${projectTitle}" has been successfully submitted and is currently under review. Our project management team will evaluate your request and respond within 2-3 business days.`,
                                time: createdDate,
                                meta: [
                                    `💰 Estimated Budget: R${Number(budget).toLocaleString()}`,
                                    `🏗️ Type: ${req.projectType || 'Construction'}`,
                                    `⏰ Status: Awaiting Review`
                                ],
                                unread: !readNotifications.includes(`pending-${requestId}`),
                                actions: [
                                    { label: 'View Request', action: 'viewRequest', requestId: requestId }
                                ],
                                requestData: req
                            });
                        }
                    });
                }

                // Add welcome notification if no other notifications
                if (allNotifications.length === 0) {
                    allNotifications.push({
                        id: 'welcome',
                        type: 'info',
                        category: 'system',
                        title: '👋 Welcome to Axis I.T Notifications',
                        body: `Hello ${currentUserName}! This is your notification center where you'll receive updates about your project requests, project progress, and important communications. Start by submitting a new project request from your dashboard.`,
                        time: new Date(),
                        meta: ['🔔 System Notification'],
                        unread: !readNotifications.includes('welcome'),
                        actions: [
                            { label: 'Submit New Request', action: 'newRequest' }
                        ]
                    });
                }

                // Sort notifications by time (newest first)
                allNotifications.sort((a, b) => b.time - a.time);

                console.log('[Notifications] Total notifications loaded:', allNotifications.length);
                updateStatistics();
                renderNotifications();
            } catch (err) {
                console.error('[Notifications] Error loading:', err);
                document.getElementById('notificationsContainer').innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">⚠️</div>
                        <div class="empty-state-text">Error loading notifications. Please refresh the page.</div>
                    </div>
                `;
            }
        }

        function updateStatistics() {
            const total = allNotifications.length;
            const unread = allNotifications.filter(n => n.unread).length;
            const accepted = allNotifications.filter(n => n.category === 'accepted').length;
            const pending = allNotifications.filter(n => n.category === 'pending').length;

            document.getElementById('totalNotifications').textContent = total;
            document.getElementById('unreadNotifications').textContent = unread;
            document.getElementById('acceptedRequests').textContent = accepted;
            document.getElementById('pendingRequests').textContent = pending;

            console.log('[Notifications] Stats - Total:', total, 'Unread:', unread, 'Accepted:', accepted, 'Pending:', pending);
        }

        function renderNotifications() {
            const container = document.getElementById('notificationsContainer');

            let filtered = allNotifications;
            if (currentFilter === 'unread') {
                filtered = allNotifications.filter(n => n.unread);
            } else if (currentFilter !== 'all') {
                filtered = allNotifications.filter(n => n.category === currentFilter);
            }

            console.log('[Notifications] Rendering', filtered.length, 'notifications (filter:', currentFilter + ')');

            if (filtered.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-state-icon">📭</div>
                        <div class="empty-state-text">
                            ${currentFilter === 'all' ? 'No notifications yet' : `No ${currentFilter} notifications`}
                        </div>
                    </div>
                `;
                return;
            }

            container.innerHTML = filtered.map(n => {
                const actionsHtml = n.actions && n.actions.length > 0
                    ? `<div class="notification-actions">
                        ${n.actions.map(a => `
                            <button class="btn btn-small" onclick='handleNotificationAction(${JSON.stringify(a).replace(/'/g, "&apos;")})'>
                                ${a.label}
                            </button>
                        `).join('')}
                       </div>`
                    : '';

                const metaHtml = Array.isArray(n.meta)
                    ? n.meta.map(m => `<span>${m}</span>`).join('')
                    : `<span>${n.meta}</span>`;

                return `
                    <div class="notification-card ${n.unread ? 'unread' : ''} ${n.type}" onclick="markAsRead('${n.id}')">
                        <div class="notification-header">
                            <div class="notification-title">
                                ${n.title}
                                ${n.unread ? '<span class="notification-badge">New</span>' : ''}
                            </div>
                            <div class="notification-time">${formatTimeAgo(n.time)}</div>
                        </div>
                        <div class="notification-body">${n.body}</div>
                        <div class="notification-meta">
                            ${metaHtml}
                        </div>
                        ${actionsHtml}
                    </div>
                `;
            }).join('');
        }

        function filterNotifications(filter) {
            currentFilter = filter;

            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            const activeBtn = document.querySelector(`[data-filter="${filter}"]`);
            if (activeBtn) {
                activeBtn.classList.add('active');
            }

            console.log('[Notifications] Filter changed to:', filter);
            renderNotifications();
        }

        function markAsRead(notificationId) {
            const notification = allNotifications.find(n => n.id === notificationId);
            if (notification && notification.unread) {
                notification.unread = false;

                if (!readNotifications.includes(notificationId)) {
                    readNotifications.push(notificationId);
                    localStorage.setItem('readNotifications_' + currentUserEmail, JSON.stringify(readNotifications));
                }

                console.log('[Notifications] Marked as read:', notificationId);
                updateStatistics();
                renderNotifications();
            }
        }

        function markAllAsRead() {
            let markedCount = 0;
            allNotifications.forEach(n => {
                if (n.unread) {
                    n.unread = false;
                    if (!readNotifications.includes(n.id)) {
                        readNotifications.push(n.id);
                        markedCount++;
                    }
                }
            });

            if (markedCount > 0) {
                localStorage.setItem('readNotifications_' + currentUserEmail, JSON.stringify(readNotifications));
                console.log('[Notifications] Marked all as read:', markedCount, 'notifications');
                updateStatistics();
                renderNotifications();
            }
        }

        function handleNotificationAction(action) {
            console.log('[Notifications] Action triggered:', action);

            switch(action.action) {
                case 'viewProject':
                    alert(`Viewing project details for: ${action.projectId}\n\nThis would redirect to the project details page.`);
                    break;
                case 'checkStatus':
                    alert(`Checking status for project: ${action.projectId}\n\nThis would show the current project status and progress.`);
                    break;
                case 'viewRequest':
                    window.location.href = '/Client/ClientRequest';
                    break;
                case 'newRequest':
                    window.location.href = '/Client/ClientRequest';
                    break;
                default:
                    console.warn('[Notifications] Unknown action:', action.action);
            }
        }

        function formatTimeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000);

            if (seconds < 60) return 'Just now';
            if (seconds < 3600) return `${Math.floor(seconds / 60)} minute${Math.floor(seconds / 60) !== 1 ? 's' : ''} ago`;
            if (seconds < 86400) return `${Math.floor(seconds / 3600)} hour${Math.floor(seconds / 3600) !== 1 ? 's' : ''} ago`;
            if (seconds < 604800) return `${Math.floor(seconds / 86400)} day${Math.floor(seconds / 86400) !== 1 ? 's' : ''} ago`;

            return formatDate(date);
        }

        function formatDate(date) {
            return new Date(date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
            });
        }

        // Initialize on page load
        window.addEventListener('DOMContentLoaded', () => {
            console.log('[Notifications] Page loaded, initializing...');
            loadNotifications();

            // Auto-refresh every 30 seconds
            setInterval(() => {
                console.log('[Notifications] Auto-refreshing...');
                loadNotifications();
            }, 30000);
        });
    </script>
</body>
</html>