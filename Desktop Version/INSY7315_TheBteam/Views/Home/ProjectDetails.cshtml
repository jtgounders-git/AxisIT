@model INSY7315_TheBteam.Models.ProjectModel
@{
    Layout = null;
    var role = ViewData["Role"]?.ToString();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@Model.Title</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        h2 { color: #333; }
        h3 { margin-top: 20px; }
        ul { list-style-type: none; padding-left: 0; }
        li { background: #f5f5f5; padding: 10px; margin-bottom: 10px; border-radius: 5px; }
        form { margin-top: 5px; }
        input { margin-right: 5px; }
        button { padding: 3px 8px; }
    </style>
</head>
<body>
    <h2>@Model.Title</h2>
    <p><strong>Budget:</strong> @Model.TotalBudget</p>
    <p><strong>Start Date:</strong> @Model.StartDate.ToShortDateString()</p>

    <h3>Phases</h3>
    <ul>
    @foreach(var ph in Model.DetailedPhases)
    {
        <li>
            <strong>@ph.Name</strong> - Budget: @ph.Budget - Deadline: @ph.Deadline.ToShortDateString()
            <br />Projected: @ph.ProjectedPercent% | Actual: @ph.ActualPercent%
            <br />Resources:
            <ul>
            @foreach(var r in ph.Resources)
            {
                <li>@r.Key : @r.Value</li>
            }
            </ul>

            @if(role == "Admin" || role == "Project Manager")
            {
                <form method="post" action="/Home/UpdatePhaseActual" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <input type="hidden" name="phaseId" value="@ph.Id" />
                    <input name="actualPercent" type="number" min="0" max="100" placeholder="Actual %" required />
                    <button type="submit">Update Actual</button>
                </form>

                <form method="post" action="/Home/AllocateResource" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <input type="hidden" name="phaseId" value="@ph.Id" />
                    <input name="resourceName" placeholder="Resource name" required />
                    <input name="amount" type="number" step="0.01" placeholder="Amount" required />
                    <button type="submit">Allocate</button>
                </form>
            }
        </li>
    }
    </ul>

    <a href="/Home/Projects">← Back to Projects</a>
</body>
</html>
